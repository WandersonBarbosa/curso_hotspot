{
  "name": "hotspot-saas",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w @hotspot/backend",
    "dev:frontend": "npm run dev -w @hotspot/frontend",
    "build:shared": "npx -y -p typescript@5.6.3 tsc -p packages/shared/tsconfig.json",
    "build:backend": "npx -y -p typescript@5.6.3 tsc -p apps/backend/tsconfig.json",
    "build:frontend": "npm run build -w @hotspot/frontend",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend",
    "db:generate": "npm run db:generate -w @hotspot/backend",
    "db:migrate": "npm run db:migrate -w @hotspot/backend",
    "db:seed": "npm run db:seed -w @hotspot/backend",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file docker/.env.example up -d --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
